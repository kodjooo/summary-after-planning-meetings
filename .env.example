# Токен Telegram-бота. Получить у @BotFather после создания бота.
TELEGRAM_BOT_TOKEN=replace_me

# API-ключ OpenAI. Получить в панели проекта OpenAI.
OPENAI_API_KEY=replace_me

# Модель для анализа транскрипции через Responses API.
OPENAI_ANALYSIS_MODEL=gpt-4.1-mini

# Уровень рассуждения модели для Responses API: low, medium или high.
OPENAI_REASONING_EFFORT=medium

# Подключение к Redis внутри Docker Compose.
REDIS_URL=redis://redis:6379/0

# Базовый публичный URL web fallback-загрузки больших файлов.
WEB_BASE_URL=http://localhost:8080

# Время жизни одноразовой ссылки на загрузку большого файла в секундах.
UPLOAD_TOKEN_TTL_SECONDS=3600

# Общие настройки приложения.
TEMP_DIR=/tmp/meeting-assistant
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=100
OPENAI_TRANSCRIPTION_MAX_FILE_SIZE_MB=24
TRANSCRIPT_CHUNK_SIZE=40000
BOT_STATUS_POLLING_TIMEOUT=30
